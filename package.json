{
  "author": "Octopus Deploy",
  "bugs": {
    "url": "https://github.com/OctopusDeploy/create-release-action/issues"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@octopusdeploy/api-client": "3.11.6",
    "tmp": "0.2.7"
  },
  "description": "GitHub Action to Create a Release in Octopus Deploy",
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@octopusdeploy/runtime-inputs": "0.16.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/jest": "29.5.14",
    "@types/json-patch": "0.0.33",
    "@types/lodash": "4.17.24",
    "@types/node": "24.7.2",
    "@types/tmp": "0.2.6",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "esbuild": "0.25.1",
    "eslint": "9.39.4",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-jest": "29.15.2",
    "globals": "16.5.0",
    "jest": "29.7.0",
    "jest-circus": "29.7.0",
    "jest-junit": "15.0.0",
    "js-yaml": "5.2.1",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3"
  },
  "homepage": "https://github.com/OctopusDeploy/create-release-action#readme",
  "jest": {
    "clearMocks": true,
    "collectCoverage": true,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "setupFiles": [
      "<rootDir>/src/test-setup.ts"
    ],
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "testRunner": "jest-circus/runner",
    "testTimeout": 10000,
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "verbose": true
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "jest-junit.xml",
    "ancestorSeperator": " > ",
    "uniqueOutputName": "false",
    "suiteNameTemplate": "{filepath}",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  },
  "keywords": [
    "cli",
    "deployment",
    "octopus-deploy",
    "github-actions"
  ],
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "name": "create-release-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OctopusDeploy/create-release-action.git"
  },
  "scripts": {
    "all": "npm run format && npm run build && npm test",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "prebuild": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --reporters=default --reporters=jest-junit",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --reporters=default --reporters=jest-junit --testPathPattern=__tests__/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --reporters=default --reporters=jest-junit --testPathPattern=__tests__/integration"
  },
  "version": "4.2.1"
}
